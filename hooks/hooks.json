{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "^/read",
        "hooks": [
          {
            "type": "command",
            "command": "valeria hook-read",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "valeria hint",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "valeria notify",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
