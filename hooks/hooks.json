{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "^/read",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'valeria hook-read'",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'valeria hint'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'valeria notify'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
